stage('test-examples') {

    if (env.SGX == "1") {
        env.MODE = "sgx"
    }
    else {
        env.MODE = "direct"
    }

    try {
            sh '''
                echo "Running Test with GRAMINE-DIRECT"
                cd CI-Examples/mariadb
                sudo -E make install-mariadb
                make clean && make ${MAKEOPTS} 
                make ${MAKEOPTS} test-gramine 2>&1 | tee RESULT
            '''
    } catch (Exception e) { }
}
