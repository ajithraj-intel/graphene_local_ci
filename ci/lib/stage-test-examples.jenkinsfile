stage('test-examples') {

    if (env.SGX == "1") {
        env.MODE = "sgx"
    }
    else {
        env.MODE = "direct"
    }

    try {
            sh '''
                #!/bin/bash
                echo Running in $0 Terminal
                echo "Running Test with GRAMINE-DIRECT"
                cd CI-Examples/mariadb
                sudo -E make install-mariadb
                make clean && make SGX=1
                make test-gramine SGX=0 2>&1 | tee RESULT
            '''
    } catch (Exception e) { }

        try {
            sh '''
                echo "Running Test with GRAMINE-SGX"
                cd CI-Examples/mariadb
                sudo -E make install-mariadb
                make clean && make SGX=1 
                make test-gramine SGX=1 2>&1 | tee RESULT
            '''
    } catch (Exception e) { }  
}
