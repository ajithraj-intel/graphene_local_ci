stage('test-examples') {

    if (env.SGX == "1") {
        env.MODE = "sgx"
    }
    else {
        env.MODE = "direct"
    }

    if (["ubuntu", "debian"].contains(env.os_release_id)) {
           try {
                  sh '''
                        cd CI-Examples/mariadb
                        sudo -E make remove-mariadb
                        sudo -E make install-mariadb
                        make clean && make SGX=1
                        make test-gramine SGX=1 2>&1 | tee RESULT
                    '''
            } catch (Exception e) { }
     }    
}
